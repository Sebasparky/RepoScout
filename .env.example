# RepoScout — local environment variables
# Copy this file to .env and fill in your values.
# The .env file should never be committed.

# ── Optional: GitHub personal access token ────────────────────────────────────
#
# RepoScout works without a token using GitHub's unauthenticated limit (60 req/hr).
# Set GITHUB_TOKEN to raise that to 5,000 req/hr.
#
# How to create a token:
#   github.com/settings/tokens → Fine-grained tokens → New token
#   No scopes required — public repo search is unauthenticated by default.

# GITHUB_TOKEN=
