{
  "name": "reposcout-video",
  "type": "module",
  "version": "0.1.0",
  "description": "RepoScout product demo video built with Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render RepoScoutDemo out/reposcout-demo.mp4",
    "render": "remotion render RepoScoutDemo out/reposcout-demo.mp4 --codec=h264",
    "generate-voiceover": "npx tsx scripts/generate-voiceover.ts"
  },
  "dependencies": {
    "@remotion/cli": "4.0.441",
    "@remotion/google-fonts": "4.0.441",
    "@remotion/media": "4.0.441",
    "@remotion/transitions": "4.0.441",
    "remotion": "4.0.441",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "typescript": "^5.4.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
